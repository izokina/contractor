 FormBox["93324", TraditionalForm]], "Output",
 Editable->False,
 CellChangeTimes->{3.9863540962964582`*^9, 3.986354132166264*^9, 
  3.98635737060511*^9},
 CellLabel->"Out[18]=",ExpressionUUID->"db8debb9-a6b9-43e0-adb2-64170bca49da"]
}, Open  ]],

Cell["\<\
Free the remaining intermediate expressions.

At this point Part3 and Part4 have already been used to construct the final \
result stored in theOutput. They are no longer needed for the rest of the \
example.

We clear Part3 and Part4 to reduce the memory used by the current Wolfram \
kernel session. ClearSystemCache[] is also called to clear internal cached \
results produced during the symbolic computation.

The printed values are diagnostic. They show the memory reported by \
MemoryInUse[] before and after clearing the intermediate expressions. The \
operating system may not show the same decrease immediately, because the \
Wolfram kernel may keep some allocated memory available for reuse.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{
  3.986354494167824*^9},ExpressionUUID->"2dcf21c3-c696-4a3b-b9e7-\
0fec916fcb22"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Memory before clearing Part1 and Part2: \>\"", ",", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"MemoryInUse", "[", "]"}], "/", 
      RowBox[{"2", "^", "30"}]}], "]"}], ",", "\"\< GiB\>\""}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"Part3", ",", "Part4"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ClearSystemCache", "[", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Memory after clearing Part1 and Part2:  \>\"", ",", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"MemoryInUse", "[", "]"}], "/", 
      RowBox[{"2", "^", "30"}]}], "]"}], ",", "\"\< GiB\>\""}], "]"}], 
  ";"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.986354134379727*^9, 3.986354135776346*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"9d65c177-576d-4d0f-98d4-72d418c81c07"],

