Cell["\<\
Benchmark environment.

The following timings were obtained on an ordinary consumer-grade laptop, not \
on a dedicated workstation or HPC node. They are intended to illustrate the \
practical relative performance of the contraction routines in a typical local \
Mathematica session.

Hardware and operating system:
\tModel: Dell Inc. Inspiron 14 5420
\tOS: Ubuntu 24.04.4 LTS
\tCPU: Intel Core i5-1235U, 10 cores / 12 threads
\tRAM: 8.0 GiB
\t
For reproducibility, the Wolfram kernel version and system identifier are \
printed below.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986286586337792*^9, 
  3.986286657034189*^9}},ExpressionUUID->"3059c058-8dc5-458e-844e-\
f2e69ce1fe4b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"$Version", ",", " ", "$SystemID"}], "}"}]], "Input",
 Editable->False,
 CellChangeTimes->{{3.9862866505678167`*^9, 3.9862866505687037`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"30fcfc6b-a099-4d6d-80d8-953e6c9f5044"],

Cell[CellGroupData[{

Cell["\<\
Test 0. Contraction of a three-graviton vertex with a graviton propagator.\
\>", "Title",
 Editable->False,
 CellChangeTimes->{{3.980241862715184*^9, 3.980241864369738*^9}, 
   3.986006593792197*^9, {3.986286299117606*^9, 
   3.9862863080109262`*^9}},ExpressionUUID->"29316d75-8626-44f8-89c5-\
7a753c0ef22c"],

Cell["\<\
We consider the three-graviton vertex in general relativity and attach a \
graviton propagator to one of its legs. All momenta and tensor indices are \
kept symbolic, and no on-shell conditions are imposed.

The input expression is stored without any preliminary simplification.
The Timing output only reports the time needed to construct the expression; \
the expression itself is suppressed by the semicolon.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986286321972247*^9, 
  3.9862863607930107`*^9}},ExpressionUUID->"46b00ce6-829f-434e-9314-\
139f697ff83c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "theInput", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"theInput", "=", 
    RowBox[{
     RowBox[{"GravitonVertex", "[", 
      RowBox[{
      "m1", ",", "n1", ",", "p1", ",", "m2", ",", "n2", ",", "p2", ",", "a1", 
       ",", "b1", ",", "p3"}], "]"}], 
     RowBox[{"GravitonPropagator", "[", 
      RowBox[{"a1", ",", "b1", ",", "m3", ",", "n3", ",", "p3"}], "]"}]}]}], 
   ";"}], "//", "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.980241883246312*^9, 3.9802419640257597`*^9}, {
   3.98024201531922*^9, 3.980242017860632*^9}, {3.981882177963428*^9, 
   3.98188218052055*^9}, 3.98193892310026*^9, 3.9819431095666933`*^9, {
   3.9858630808730383`*^9, 3.985863086834522*^9}, {3.985914071921282*^9, 
   3.9859140923031683`*^9}, {3.985914199122262*^9, 3.985914222440583*^9}, {
   3.986260045366186*^9, 3.986260047390627*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"2cb660ce-a988-4d05-a73e-11ef7cec0290"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0.024776`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986294743162435*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"e902e8e3-dd54-4ec4-bd6d-4a70db204348"]
}, Open  ]],

Cell["\<\
We now contract the same input in two different ways.

theOutput0: The expression is contracted with the standard FeynCalc routine \
Contract.
theOutput1: The expression is contracted with FeynGravContractor, which \
delegates the tensor contraction to Contractor.

Only timings are printed; the contracted expressions are stored in the \
variables theOutput0 and theOutput1.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986286383206942*^9, 
  3.986286436166917*^9}},ExpressionUUID->"a97f6199-b060-4566-bec1-\
f1499dc43bd1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"theOutput0", ",", "theOutput1"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"theOutput0", "=", 
    RowBox[{"Contract", "[", "theInput", "]"}]}], ";"}], "//", 
  "Timing"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"theOutput1", "=", 
    RowBox[{"FeynGravContractor", "[", "theInput", "]"}]}], ";"}], "//", 
  "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.98591409607828*^9, 3.985914124157308*^9}, {
  3.985925576762508*^9, 3.985925577642128*^9}, {3.985932828717586*^9, 
  3.985932836708273*^9}, {3.985933849652544*^9, 3.985933859380536*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"9dc93186-4b22-477a-b238-cc72d5ae363a"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"1.030949`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986294744215663*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"187af740-2674-4855-acec-51a4e625a585"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0.13893`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986294744365344*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"ba293eb5-4e40-468c-8f77-c09cbb585f5a"]
}, Open  ]],

Cell["\<\
Consistency check.

We verify that the FeynCalc-contracted expression and the \
FeynGravContractor-contracted expression are algebraically equivalent. The \
equality is simplified using FeynCalc\[CloseCurlyQuote]s Calc followed by \
Mathematica\[CloseCurlyQuote]s Simplify. The expected result is True.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.9862864544894733`*^9, 
  3.9862864744341288`*^9}},ExpressionUUID->"d5df470c-3d8a-48c4-8b98-\
66b785b21387"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"theOutput0", "==", "theOutput1"}], "//", "Calc"}], "//", 
   "Simplify"}], "//", "Timing"}]], "Input",
 Editable->False,
 CellChangeTimes->{{3.981882246009334*^9, 3.981882247980832*^9}, {
   3.981938927931492*^9, 3.981938928735278*^9}, 3.9819431095693274`*^9, {
   3.985863137405485*^9, 3.98586314128759*^9}, {3.985914130017927*^9, 
   3.985914132931137*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"3330576c-f3e3-4bb7-a9f0-6e3665b50c51"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"2.581999`", ",", "True"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986294746993964*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"08fbaf89-6c1a-4c5b-920e-3ac9642af651"]
}, Open  ]],

