 CellLabel->"Out[6]=",ExpressionUUID->"1928b54a-e51c-40fa-a176-5800a89931e0"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"1.10881`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.9862947846579857`*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"950cbb3b-e369-4efe-a96e-b5dde2450bdc"]
}, Open  ]],

Cell["\<\
Consistency check.

We verify that the two contraction methods give algebraically equivalent \
results. The equality is simplified using FeynCalc\[CloseCurlyQuote]s Calc \
followed by Mathematica\[CloseCurlyQuote]s Simplify. The expected result is \
True.

This check tests agreement of the final symbolic expressions; it does not \
assign any physical interpretation to the artificial product of vertices.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.9862869382889843`*^9, 
  3.986286957451733*^9}},ExpressionUUID->"916e2137-b60a-4789-90b5-\
69969928dd59"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"theOutput0", "==", "theOutput1"}], "//", "Calc"}], "//", 
   "Simplify"}], "//", "Timing"}]], "Input",
 Editable->False,
 CellChangeTimes->{{3.981882246009334*^9, 3.981882247980832*^9}, {
   3.981882285446871*^9, 3.981882287255413*^9}, {3.981938916015787*^9, 
