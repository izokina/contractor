Cell["\<\
The estimate shows that a direct contraction of Part4 Part3 would require \
handling millions of symbolic products. On the benchmark laptop used here, \
this is too large to process as a single input to FeynGravContractor. \
Instead, we split Part4 into consecutive chunks of 2000 additive terms. Each \
chunk is multiplied by the full expression Part3 and passed to \
FeynGravContractor separately. The partial contracted results are accumulated \
in theOutput.

The printed messages report the chunk currently being processed and the \
memory used by the current Wolfram kernel session. These diagnostics are \
included to make the memory behaviour of the staged calculation visible.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{
  3.986354419050436*^9, {3.986355949138269*^9, 3.986355950025147*^9}, {
   3.9863559861209183`*^9, 3.986355986694499*^9}, 3.9863560199780083`*^9, 
   3.986356484466879*^9},ExpressionUUID->"891ba504-8861-4bbd-94c2-\
d85d45cc261c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", "theOutput", "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"theOutput", "=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"theChunkSize", "=", "2000"}], ",", 
        RowBox[{"theNumberOfTerms", "=", 
         RowBox[{"Length", "[", "Part4", "]"}]}], ",", "theNumberOfChunks", 
        ",", "theResult", ",", "theChunkIndex", ",", "theFirstTerm", ",", 
        "theLastTerm"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"theNumberOfChunks", "=", 
        RowBox[{"Ceiling", "[", 
         RowBox[{"theNumberOfTerms", "/", "theChunkSize"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<Number of terms in Part4: \>\"", ",", "theNumberOfTerms"}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Chunk size: \>\"", ",", "theChunkSize"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Number of chunks: \>\"", ",", "theNumberOfChunks"}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Initial memory use: \>\"", ",", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"MemoryInUse", "[", "]"}], "/", 
           RowBox[{"2", "^", "30"}]}], "]"}], ",", "\"\< GiB\>\""}], "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"theResult", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{
          RowBox[{"theFirstTerm", "=", 
           RowBox[{"1", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"theChunkIndex", "-", "1"}], ")"}], " ", 
             "theChunkSize"}]}]}], ";", "\[IndentingNewLine]", "\t", 
          RowBox[{"theLastTerm", "=", 
           RowBox[{"Min", "[", 
            RowBox[{
             RowBox[{"theChunkIndex", " ", "theChunkSize"}], ",", 
             "theNumberOfTerms"}], "]"}]}], ";", "\[IndentingNewLine]", "\t", 
          
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<Processing chunk \>\"", ",", "theChunkIndex", ",", 
            "\"\< of \>\"", ",", "theNumberOfChunks", ",", "\"\<  terms \>\"",
             ",", "theFirstTerm", ",", "\"\<--\>\"", ",", "theLastTerm", ",", 
            "\"\<  memory: \>\"", ",", 
            RowBox[{"N", "[", 
             RowBox[{
              RowBox[{"MemoryInUse", "[", "]"}], "/", 
              RowBox[{"2", "^", "30"}]}], "]"}], ",", "\"\< GiB\>\""}], "]"}],
           ";", "\[IndentingNewLine]", "\t", 
          RowBox[{"theResult", "=", 
           RowBox[{"theResult", "+", 
            RowBox[{"(", 
             RowBox[{"Simplify", "/@", 
              RowBox[{"FeynGravContractor", "[", 
               RowBox[{
                RowBox[{"Part4", "[", 
                 RowBox[{"[", 
                  RowBox[{"theFirstTerm", ";;", "theLastTerm"}], "]"}], "]"}],
                 " ", "Part3"}], "]"}]}], ")"}]}]}], ";", 
          "\[IndentingNewLine]", "\t", 
          RowBox[{"ClearSystemCache", "[", "]"}], ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"theChunkIndex", ",", "1", ",", "theNumberOfChunks"}], 
          "}"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Final memory use: \>\"", ",", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"MemoryInUse", "[", "]"}], "/", 
           RowBox[{"2", "^", "30"}]}], "]"}], ",", "\"\< GiB\>\""}], "]"}], 
       ";", "\[IndentingNewLine]", "theResult"}]}], "]"}]}], ";"}], "//", 
  "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.9863517783352222`*^9, 3.98635194006176*^9}, {
   3.986351989379713*^9, 3.9863519900116253`*^9}, {3.986352056305133*^9, 
