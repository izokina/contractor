Cell[CellGroupData[{

Cell["Test 1. Synthetic contraction benchmark", "Title",
 Editable->False,
 CellChangeTimes->{{3.980241862715184*^9, 3.980241864369738*^9}, {
  3.98143541304096*^9, 3.981435413160273*^9}, {3.986286738101694*^9, 
  3.986286738702519*^9}, {3.986286771844864*^9, 
  3.986286773841426*^9}},ExpressionUUID->"1b497f1f-536e-465a-a582-\
8f3d87afcf2d"],

Cell["\<\
This example is not intended to represent a physical scattering amplitude or \
a complete Feynman-diagram contribution. Instead, it is a synthetic stress \
test for tensor contractions.

We form the product of two identical three-graviton vertices in general \
relativity, with all Lorentz indices paired between the two vertices. No \
on-shell conditions, momentum-conservation identities, gauge choices, or \
kinematic simplifications are imposed at the level of the input expression.

The purpose of the example is to compare the practical performance of \
FeynCalc\[CloseCurlyQuote]s Contract with FeynGravContractor on a large \
symbolic tensor expression.

The Timing output reports only the time needed to construct and store the \
input expression; the expression itself is suppressed by the semicolon.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986286789517022*^9, 
  3.986286856296339*^9}},ExpressionUUID->"5a9f1f3a-b1f7-4c9a-a8b5-\
b44bf7ee9fc4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "theInput", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"theInput", "=", 
    RowBox[{
     RowBox[{"GravitonVertex", "[", 
      RowBox[{
      "m1", ",", "n1", ",", "p1", ",", "m2", ",", "n2", ",", "p2", ",", "m3", 
       ",", "n3", ",", "p3"}], "]"}], 
     RowBox[{"GravitonVertex", "[", 
      RowBox[{
      "m1", ",", "n1", ",", "p1", ",", "m2", ",", "n2", ",", "p2", ",", "m3", 
       ",", "n3", ",", "p3"}], "]"}]}]}], ";"}], "//", "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.981435467244329*^9, 3.9814355035115623`*^9}, {
   3.981938907317015*^9, 3.981938908622182*^9}, 3.981943109570303*^9, {
