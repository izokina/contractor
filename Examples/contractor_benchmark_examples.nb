Cell["\<\
Four-graviton contact contribution.

This cell computes the contribution from the four-graviton contact vertex. \
This term is required for the complete tree-level amplitude and must be added \
to the three exchange-channel contributions.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986288434658135*^9, 
  3.986288444890575*^9}},ExpressionUUID->"0c17a82c-50e0-4a74-949e-\
ef0363d29fc4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AmplitudeContactInteraction", "=", 
    RowBox[{"TrickMandelstam", "[", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{"ScalarProductExpand", "[", 
        RowBox[{"FeynGravContractor", "[", 
         RowBox[{
          RowBox[{"GravitonVertex", "[", 
           RowBox[{
           "\[Mu]1", ",", "\[Nu]1", ",", "p1", ",", "\[Mu]2", ",", "\[Nu]2", 
            ",", "p2", ",", "\[Mu]3", ",", "\[Nu]3", ",", "p3", ",", "\[Mu]4",
             ",", "\[Nu]4", ",", "p4"}], "]"}], 
          RowBox[{"PolarizationTensor", "[", 
           RowBox[{"\[Mu]1", ",", "\[Nu]1", ",", "p1"}], "]"}], 
          RowBox[{"PolarizationTensor", "[", 
           RowBox[{"\[Mu]2", ",", "\[Nu]2", ",", "p2"}], "]"}], 
          RowBox[{"ComplexConjugate", "[", 
           RowBox[{
            RowBox[{"PolarizationTensor", "[", 
             RowBox[{"\[Mu]3", ",", "\[Nu]3", ",", "p3"}], "]"}], 
            RowBox[{"PolarizationTensor", "[", 
             RowBox[{"\[Mu]4", ",", "\[Nu]4", ",", "p4"}], "]"}]}], "]"}]}], 
         "]"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "t", ",", "u", ",", "0"}], "}"}]}], "]"}]}], ";"}], "//",
   "Timing"}]], "Input",
 Editable->False,
 CellChangeTimes->{{3.894586718088767*^9, 3.894586749992611*^9}, {
   3.89458687743661*^9, 3.894586902469788*^9}, {3.8945869502856617`*^9, 
   3.894586955045238*^9}, {3.894587147330565*^9, 3.894587181059105*^9}, {
   3.894587251132522*^9, 3.894587355294403*^9}, {3.8945874352410383`*^9, 
   3.894587436359736*^9}, 3.986278896911488*^9, {3.986279101761733*^9, 
   3.986279106030939*^9}, {3.986285053628585*^9, 3.98628505386885*^9}},
 CellLabel->"In[29]:=",ExpressionUUID->"5d4fa82b-a36d-4576-8f43-7e110fc6c7e6"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0.873293`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.9863009188565273`*^9},
 CellLabel->"Out[29]=",ExpressionUUID->"ebcd19ca-3896-433d-b058-bfa93a5ae4c3"]
}, Open  ]],

Cell["\<\
Complete four-graviton tree-level amplitude.

The full tree-level result is obtained by summing the s-, t- and u-channel \
exchange diagrams and the four-graviton contact interaction. The final call \
to TrickMandelstam reduces the expression using the massless four-point \
relation s + t + u = 0. The result still contains the helicity labels h1, h2, \
h3 and h4.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986288463099477*^9, 
  3.986288480290487*^9}},ExpressionUUID->"0fd4a63c-2e72-450d-9633-\
7c3c452a56ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TheCompleteAmplitude", " ", "=", " ", 
    RowBox[{"TrickMandelstam", "[", 
     RowBox[{
      RowBox[{
      "AmplitudeSChannel", "+", "AmplitudeTChannel", "+", "AmplitudeUChannel",
        "+", "AmplitudeContactInteraction"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "t", ",", "u", ",", "0"}], "}"}]}], "]"}]}], ";"}], "//",
   "Timing"}]], "Input",
 Editable->False,
 CellChangeTimes->{{3.894587420399425*^9, 3.894587422375812*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"8cd1fb01-183a-4394-bb0c-641dd0c3c5d7"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0.040303`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986300918917697*^9},
 CellLabel->"Out[30]=",ExpressionUUID->"a8c2a0a9-c992-4d18-bafa-106082f07815"]
}, Open  ]],

Cell["\<\
Helicity-amplitude checks.

We now substitute selected helicity assignments and set D -> 4. The resulting \
expressions are compared with the known four-dimensional on-shell \
four-graviton helicity amplitudes.

These checks are validation tests for the complete amplitude. They confirm \
both the non-vanishing MHV-type configurations and the expected vanishing of \
the all-plus / single-minus-type configurations in the chosen convention.

The expected output of each line is True.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.98628849521122*^9, 
  3.986288524516445*^9}},ExpressionUUID->"14c726f1-7ecb-480d-bd96-\
5fef8e8a9037"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"TrickMandelstam", "[", 
    RowBox[{
     RowBox[{"TheCompleteAmplitude", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"h1", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h2", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h3", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h4", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"D", "\[Rule]", "4"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "t", ",", "u", ",", "0"}], "}"}]}], "]"}], "\[Equal]", 
   RowBox[{"\[ImaginaryI]", " ", 
    FractionBox[
     SuperscriptBox["\[Kappa]", "2"], "4"], 
    FractionBox[
     SuperscriptBox["s", "4"], 
     RowBox[{"s", " ", "t", " ", "u"}]]}]}], "//", 
  "Simplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TrickMandelstam", "[", 
    RowBox[{
     RowBox[{"TheCompleteAmplitude", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"h1", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h2", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"h3", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h4", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"D", "\[Rule]", "4"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "t", ",", "u", ",", "0"}], "}"}]}], "]"}], "\[Equal]", 
   RowBox[{"\[ImaginaryI]", " ", 
    FractionBox[
     SuperscriptBox["\[Kappa]", "2"], "4"], 
    FractionBox[
     SuperscriptBox["u", "4"], 
     RowBox[{"s", " ", "t", " ", "u"}]]}]}], "//", 
  "Simplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TrickMandelstam", "[", 
    RowBox[{
     RowBox[{"TheCompleteAmplitude", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"h1", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h2", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"h3", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"h4", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"D", "\[Rule]", "4"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "t", ",", "u", ",", "0"}], "}"}]}], "]"}], "\[Equal]", 
   RowBox[{"\[ImaginaryI]", " ", 
    FractionBox[
     SuperscriptBox["\[Kappa]", "2"], "4"], 
    FractionBox[
     SuperscriptBox["t", "4"], 
     RowBox[{"s", " ", "t", " ", "u"}]]}]}], "//", 
  "Simplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TrickMandelstam", "[", 
    RowBox[{
     RowBox[{"TheCompleteAmplitude", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"h1", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h2", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
        RowBox[{"h3", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"h4", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"D", "\[Rule]", "4"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"s", ",", "t", ",", "u", ",", "0"}], "}"}]}], "]"}], "\[Equal]",
    "0"}], "//", "Simplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TrickMandelstam", "[", 
    RowBox[{
     RowBox[{"TheCompleteAmplitude", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"h1", "\[Rule]", 
         RowBox[{"+", "1"}]}], ",", 
