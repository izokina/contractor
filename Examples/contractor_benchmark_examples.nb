 RowBox[{"Length", "[", "Part4", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Length", "[", "Part3", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Length", "[", "Part3", "]"}], 
  RowBox[{"Length", "[", "Part4", "]"}]}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.9863487961969433`*^9, 3.986348818447385*^9}},
