Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0.022542`", ",", "True"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986294784729969*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"ac8c7f35-422b-4ee7-b4f9-4ff00da4c599"]
}, Open  ]],

