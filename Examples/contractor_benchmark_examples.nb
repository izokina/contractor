 CellChangeTimes->{3.9862949362262173`*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"5edc8abd-c9f3-4a09-a485-c218f47fce67"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"13.489805`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 CellChangeTimes->{3.986294951495159*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"8b92c04b-756c-424a-84b2-48b6a58c270f"]
}, Open  ]],

Cell["\<\
Consistency check.

We verify that the two contraction methods give algebraically equivalent \
symbolic results. The equality is first processed with FeynCalc\
\[CloseCurlyQuote]s Calc and then simplified with Mathematica\
\[CloseCurlyQuote]s Simplify. The expected result is True.

This check may take substantially longer than the contraction step itself: \
the two methods can return equivalent expressions in different algebraic \
forms, so the equality test requires additional simplification before \
Mathematica can recognize the two sides as identical.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.9862872562984858`*^9, 
  3.986287281713159*^9}},ExpressionUUID->"41bcca41-b278-4df0-8712-\
1133e644f7d5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"theOutput0", "==", "theOutput1"}], "//", "Calc"}], "//", 
   "Simplify"}], "//", "Timing"}]], "Input",
 Editable->False,
 CellChangeTimes->{{3.986006844474855*^9, 3.986006853191553*^9}, 
   3.986007063234001*^9, {3.986007311386676*^9, 3.986007312447804*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"d1fa8ce9-b0fb-4bf8-b0c4-ad6b8540fbb6"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
