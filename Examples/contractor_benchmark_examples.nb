Cell["\<\
The same input expression is now contracted in two different ways.

theOutput0: The expression is contracted using FeynCalc\[CloseCurlyQuote]s \
standard Contract routine.
theOutput1: The expression is contracted using FeynGravContractor, which \
sends the tensor-contraction task to Contractor.

Only the timings are printed. The contracted symbolic expressions are stored \
in the variables theOutput0 and theOutput1.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986286873753784*^9, 
  3.986286911390232*^9}},ExpressionUUID->"501826dc-961c-4643-8b78-\
e0f772097d24"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"theOutput0", ",", "theOutput1"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"theOutput0", "=", 
    RowBox[{"Contract", "[", "theInput", "]"}]}], ";"}], "//", 
  "Timing"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"theOutput1", "=", 
    RowBox[{"FeynGravContractor", "[", "theInput", "]"}]}], ";"}], "//", 
  "Timing"}]}], "Input",
 Editable->False,
