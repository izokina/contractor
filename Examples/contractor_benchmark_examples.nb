Cell[CellGroupData[{

Cell["Test 3. Special-character symbol test.", "Title",
 Editable->False,
 CellChangeTimes->{{3.981439810443247*^9, 3.98143981492326*^9}, 
   3.9818863281961203`*^9, {3.981890489247951*^9, 3.981890489370213*^9}, {
   3.981890578468575*^9, 3.981890578602498*^9}, {3.986287456213805*^9, 
   3.986287458496647*^9}},ExpressionUUID->"9510bf6e-8a97-44a3-a2fb-\
94614db2800d"],

Cell["\<\
This test repeats the tensor structure of Test 2, but replaces the \
ASCII-style symbols m1, n1, p1, ... by Wolfram special-character symbols such \
as \[Mu]1, \[Nu]1, \[Alpha]1, \[Beta]1 and \[ScriptP]1.

The purpose of this example is not to introduce a new physical calculation. \
Instead, it checks that FeynGravContractor handles non-ASCII Wolfram symbols \
correctly when tensor expressions are passed to Contractor and converted back \
to Wolfram Language expressions.

The expression is again one exchange-channel four-graviton tree-level \
building block: two three-graviton vertices connected by one graviton \
propagator. As in Test 2, no on-shell conditions, gauge choices, \
transversality conditions, or momentum-conservation simplifications are \
imposed.

The Timing output reports only the time needed to construct and store the \
input expression; the expression itself is suppressed by the semicolon.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.986287476127383*^9, 
  3.986287533267746*^9}},ExpressionUUID->"9c373565-3793-46b7-8533-\
546995a096ce"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "theInput", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"theInput", "=", 
    RowBox[{
     RowBox[{"GravitonVertex", "[", 
      RowBox[{
      "\[Mu]1", ",", "\[Nu]1", ",", "\[ScriptP]1", ",", "\[Mu]2", ",", 
       "\[Nu]2", ",", "\[ScriptP]2", ",", "\[Alpha]1", ",", "\[Beta]1", ",", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"\[ScriptP]1", "+", "\[ScriptP]2"}], ")"}]}]}], "]"}], 
     RowBox[{"GravitonPropagator", "[", 
      RowBox[{
      "\[Alpha]1", ",", "\[Beta]1", ",", "\[Alpha]2", ",", "\[Beta]2", ",", 
       RowBox[{"\[ScriptP]1", "+", "\[ScriptP]2"}]}], "]"}], 
     RowBox[{"GravitonVertex", "[", 
      RowBox[{"\[Alpha]2", ",", "\[Beta]2", ",", 
       RowBox[{"\[ScriptP]1", "+", "\[ScriptP]2"}], ",", "\[Mu]3", ",", 
       "\[Nu]3", ",", "\[ScriptP]3", ",", "\[Mu]4", ",", "\[Nu]4", ",", 
       "\[ScriptP]4"}], "]"}]}]}], ";"}], "//", "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.981439867294203*^9, 3.981439963418564*^9}, {
   3.981886455252936*^9, 3.981886460522887*^9}, {3.981888048530342*^9, 
   3.9818880492796793`*^9}, {3.981890522007934*^9, 3.981890540106439*^9}, {
   3.981939036110547*^9, 3.981939037325794*^9}, 3.981943109574853*^9, {
   3.985914378141294*^9, 3.98591438451441*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"5f20d2d4-f118-46bd-a441-a32816c2aa69"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"0.021327`", ",", "Null"}], "}"}], TraditionalForm]], "Output",
 Editable->False,
 CellChangeTimes->{3.986298425518649*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"52bcdf9e-7fbb-4040-a4eb-f20aae0fadf0"]
}, Open  ]],

