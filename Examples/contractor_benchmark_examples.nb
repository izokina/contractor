Cell[CellGroupData[{

Cell["\<\
Test 5. Pure graviton triangle diagram in general relativity.\
\>", "Title",
 Editable->False,
 CellChangeTimes->{{3.985220372618548*^9, 3.985220374046081*^9}, 
   3.985262257202323*^9, {3.986283999674951*^9, 3.986283999827888*^9}, {
   3.9863475985817013`*^9, 
   3.986347601166609*^9}},ExpressionUUID->"4636f799-abd6-47d8-adcf-\
8dff1d3a09d2"],

Cell["\<\
This example evaluates a one-loop triangle diagram built from three \
three-graviton vertices and three internal graviton propagators. The three \
external graviton legs carry momenta p1, p2 and p3, while l denotes the loop \
momentum. This is not meant to represent the complete one-loop three-graviton \
amplitude. In particular, no ghost-loop contribution, other one-loop \
topologies, counterterm contribution, loop integration, on-shell conditions, \
transversality conditions, gauge choices, or momentum-conservation \
simplifications are imposed here. The purpose of the example is to \
demonstrate how FeynGravContractor can be used on a large symbolic tensor \
expression that is too large to handle conveniently as one monolithic input \
expression on an ordinary laptop.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{
  3.9863476119081078`*^9, {3.986355812538114*^9, 
   3.986355860398612*^9}},ExpressionUUID->"e85530e2-a408-4d4d-a7d6-\
eb7a23bc03ab"],

Cell["\<\
The full product of the three vertices and three propagators is very large. \
On the benchmark machine used for these examples, trying to construct and \
contract the whole expression at once may exhaust the available memory. \
Therefore we evaluate the diagram in stages.\
\>", "Text",
 Editable->False,
 CellChangeTimes->{
  3.9863476119081078`*^9, {3.986355812538114*^9, 
   3.986355859270342*^9}},ExpressionUUID->"7a4c0067-31a9-4ddc-b525-\
9926f2196abc"],

Cell[TextData[{
 StyleBox["Step 1.",
  FontWeight->"Bold"],
 " Local vertex-propagator contractions.\n\nWe split the triangle into three \
smaller vertex-propagator blocks. Each block contains one three-graviton \
vertex and one adjacent internal graviton propagator.\n\nPart1 contains the \
vertex attached to the external leg (p1, \[Mu]1, \[Nu]1) and the propagator \
carrying loop momentum l.\nPart2 contains the vertex attached to the external \
leg (p2, \[Mu]2, \[Nu]2) and the propagator carrying momentum p2 + l.\nPart3 \
contains the vertex attached to the external leg (p3, \[Mu]3, \[Nu]3) and the \
propagator carrying momentum p2 + p3 + l.\n\nThe free Lorentz indices left in \
Part1, Part2 and Part3 are chosen so that the three blocks can be multiplied \
and contracted pairwise in the subsequent steps.\n\nThe scalar products \
involving sums of momenta are expanded before the tensor contraction. After \
each contraction, Simplify /@ applies Simplify term by term, rather than \
asking Mathematica to simplify the whole large expression globally."
}], "Text",
 Editable->False,
 CellChangeTimes->{
  3.986347659083687*^9, {3.986355877374844*^9, 
   3.9863558898564034`*^9}},ExpressionUUID->"be4e22c1-07aa-4dcb-9124-\
0e7898d9b9fe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"Part1", ",", "Part2", ",", "Part3"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Part1", "=", 
    RowBox[{"Simplify", "/@", 
     RowBox[{"FeynGravContractor", "[", 
      RowBox[{"ScalarProductExpand", "[", "   ", 
       RowBox[{
        RowBox[{"GravitonVertex", "[", 
         RowBox[{
         "\[Mu]1", ",", "\[Nu]1", ",", "p1", ",", "\[Alpha]1", ",", 
          "\[Beta]1", ",", 
          RowBox[{"-", "l"}], ",", "\[Rho]1", ",", "\[Sigma]1", ",", 
          RowBox[{
           RowBox[{"-", "p1"}], "+", "l"}]}], "]"}], 
        RowBox[{"GravitonPropagator", "[", 
         RowBox[{
         "\[Alpha]1", ",", "\[Beta]1", ",", "\[Alpha]2", ",", "\[Beta]2", ",",
           "l"}], "]"}]}], "   ", "]"}], "]"}]}]}], ";"}], "//", 
  "Timing"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Part2", "=", 
    RowBox[{"Simplify", "/@", 
     RowBox[{"FeynGravContractor", "[", 
      RowBox[{"ScalarProductExpand", "[", "   ", 
       RowBox[{
        RowBox[{"GravitonVertex", "[", 
         RowBox[{
         "\[Mu]2", ",", "\[Nu]2", ",", "p2", ",", "\[Alpha]2", ",", 
          "\[Beta]2", ",", "l", ",", "\[Rho]2", ",", "\[Sigma]2", ",", 
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"p2", "+", "l"}], ")"}]}]}], "]"}], 
        RowBox[{"GravitonPropagator", "[", 
         RowBox[{
         "\[Rho]2", ",", "\[Sigma]2", ",", "\[Rho]3", ",", "\[Sigma]3", ",", 
          RowBox[{"p2", "+", "l"}]}], "]"}]}], "   ", "]"}], "]"}]}]}], ";"}],
   "//", "Timing"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Part3", "=", 
    RowBox[{"Simplify", "/@", 
     RowBox[{"FeynGravContractor", "[", 
      RowBox[{"ScalarProductExpand", "[", "   ", 
       RowBox[{
        RowBox[{"GravitonVertex", "[", 
         RowBox[{
         "\[Mu]3", ",", "\[Nu]3", ",", "p3", ",", "\[Rho]3", ",", "\[Sigma]3",
           ",", 
          RowBox[{"p2", "+", "l"}], ",", "\[Alpha]3", ",", "\[Beta]3", ",", 
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"p2", "+", "p3", "+", "l"}], ")"}]}]}], "]"}], 
        RowBox[{"GravitonPropagator", "[", 
         RowBox[{
         "\[Alpha]3", ",", "\[Beta]3", ",", "\[Rho]1", ",", "\[Sigma]1", ",", 
          
          RowBox[{"p2", "+", "p3", "+", "l"}]}], "]"}]}], "   ", "]"}], 
      "]"}]}]}], ";"}], "//", "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.986288831948687*^9, 3.986288832617009*^9}, {
  3.986346789023909*^9, 3.986346816667824*^9}, {3.986346994102824*^9, 
