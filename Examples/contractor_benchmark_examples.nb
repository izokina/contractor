Cell[TextData[{
 StyleBox["Step 2.",
  FontWeight->"Bold"],
 " First pairwise contraction.\n\nWe now multiply Part1 and Part2 and \
contract their common internal Lorentz indices. The result is stored in \
Part4.\n\nThis staged contraction is intentionally used instead of forming \
Part1 Part2 Part3 at once. It keeps the intermediate expressions smaller and \
makes the calculation less memory-intensive.\n\nAgain, the simplification is \
performed term by term using Simplify /@."
}], "Text",
 Editable->False,
 CellChangeTimes->{
  3.986347687481759*^9},ExpressionUUID->"0a8033f1-d9d7-4ef7-b5cb-\
3c12f41fd736"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "Part4", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Part4", "=", 
    RowBox[{"Simplify", "/@", 
     RowBox[{"FeynGravContractor", "[", "   ", 
      RowBox[{"Part1", " ", "Part2"}], "   ", "]"}]}]}], ";"}], "//", 
  "Timing"}]}], "Input",
 Editable->False,
 CellChangeTimes->{{3.986346902298895*^9, 3.986346916840304*^9}, {
  3.9863469802761374`*^9, 3.986346985150623*^9}, {3.986347032195038*^9, 
  3.986347042007489*^9}, {3.986347178712034*^9, 3.986347184782127*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"8094384c-1b41-4285-a6c9-54670e54fb85"],

